      ],
      notes: [
        "Bebe ne peut pas tenir eveille plus de 60 a 90 min",
        "Les coliques disparaissent vers 3 mois",
        "Inconsolable depuis plus de 2h : consulter",
      ],
    },
    secours: {
      bg: '#FDECEA',
      tc: '#A03030',
      etapes: [
        { n: "!", titre: "Evaluer et appeler", texte: "Bebe ne reagit pas : compose le 15 ou le 18 immediatement. Ne raccroche pas." },
