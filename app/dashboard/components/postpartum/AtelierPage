      ],
      notes: [
        "Uniquement sur le dos, jamais sur le ventre",
        "Arreter des que bebe commence a se retourner (vers 2 mois)",
        "Hanches libres pour prevenir la dysplasie",
      ],
    },
    apaisement: {
      bg: '#E4F5EC',
      tc: '#0D6B40',
      etapes: [
        { n: "1", titre: "Le peau a peau", texte: "Bebe sur ta poitrine nue, tete sur le cote. Ta chaleur, ton rythme cardiaque et ton odeur sont les meilleurs calmants." },
