      bg: '#FFF7E0',
      tc: '#8A6010',
      etapes: [
        { n: "1", titre: "Prepare la zone", texte: "Rassemble tout avant de commencer : couche propre, lingettes, creme si besoin. Ne laisse jamais bebe seul sur la table a langer." },
